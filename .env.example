# Cloud Agent Platform — 环境变量示例
# 复制为 .env 后填入真实值。.env 已被 .gitignore 忽略，切勿提交真实密钥。

# ── 数据库（Neon Postgres）────────────────────────────────────────────
# Prisma 7 运行时走 driver adapter，CLI（migrate/db push）从此变量读取连接串。
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── 访问门禁（替代登录/计费）──────────────────────────────────────────
# 逗号分隔的有效邀请码；服务端二次校验，前端缓存不算数。
INVITE_CODES="demo-invite-001,demo-invite-002"

# ── LLM（pi-ai，仅 OpenAI 协议；走中转站 baseURL）─────────────────────
# 只用 OpenAI 兼容协议（api: "openai-completions"）。指向中转站 / 自建网关。
# 三者都不填或 OPENAI_API_KEY 为空时，自动回退 faux provider（测试 / 无 key 也能跑）。
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://your-relay.example.com/v1"
LLM_MODEL="gpt-4o-mini"

# ── 沙箱隔离后端 ──────────────────────────────────────────────────────
# "local"  = LocalSandbox（临时目录，零外部依赖，测试 / 本地默认）
# "vercel" = VercelSandbox（Firecracker microVM，生产隔离）
SANDBOX_PROVIDER="local"

# ── Vercel Sandbox 认证（仅 SANDBOX_PROVIDER=vercel 时需要）───────────
# 主路径：只需 VERCEL_OIDC_TOKEN。@vercel/sandbox 内置 dev-credentials 会自动
# 从环境读取它，Sandbox.getOrCreate()/create() 无需显式传 credentials。
# 本地用 `vercel link` + `vercel env pull` 生成（写入 .env.local）；
# 部署在 Vercel 上时自动注入并轮换。该 token 是 JWT，payload 内含
# owner_id(=teamId) 与 project_id，需要显式 Credentials 时（如 Sandbox.list 清理）
# 解析它即可，无需额外变量。
VERCEL_OIDC_TOKEN=""

# 可选：OIDC token 缺失时的兜底（如无 OIDC 的 CI / cron）。
# 个人 access token 路径；projectId 缺省时回退读 .vercel/project.json。
# VERCEL_TOKEN=""
# VERCEL_TEAM_ID=""
# VERCEL_PROJECT_ID=""
