# Cloud Agent Platform — 环境变量示例
# 复制为 .env 后填入真实值。.env 已被 .gitignore 忽略，切勿提交真实密钥。

# ── 数据库（Neon Postgres）────────────────────────────────────────────
# Prisma 7 运行时走 driver adapter，CLI（migrate/db push）从此变量读取连接串。
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── 访问门禁（替代登录/计费）──────────────────────────────────────────
# 逗号分隔的有效邀请码；服务端二次校验，前端缓存不算数。
INVITE_CODES="demo-invite-001,demo-invite-002"

# ── LLM（pi-ai，仅 OpenAI 协议；走中转站 baseURL）─────────────────────
# 只用 OpenAI 兼容协议（api: "openai-completions"）。指向中转站 / 自建网关。
# 三者都不填或 OPENAI_API_KEY 为空时，自动回退 faux provider（测试 / 无 key 也能跑）。
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://your-relay.example.com/v1"
LLM_MODEL="gpt-4o-mini"

# ── 沙箱隔离（Vercel Sandbox，Firecracker microVM）─────────────────────
# 业务测试与生产都跑在真实 Vercel 沙箱上（无 LocalSandbox）。认证用以下任一：
#   - VERCEL_TOKEN（个人 access token，永不过期，推荐）；teamId/projectId 缺省时
#     从 .env.local 的 OIDC token 自动解析
#   - 或 `vercel link` + `vercel env pull` 写入 .env.local 的 VERCEL_OIDC_TOKEN
# 本机访问 vercel.com 若被网络阻断，需开全局/TUN 代理；部署在 Vercel 上无此问题。
VERCEL_TOKEN=""
# 可选（缺省从 .env.local 的 OIDC token 的 owner_id/project_id 解析）：
# VERCEL_TEAM_ID=""
# VERCEL_PROJECT_ID=""
